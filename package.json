{
  "name": "homeconnect-api-cli",
  "version": "0.1.0",
  "description": "Home Connect CLI",
  "type": "module",
  "bin": {
    "hc": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "biome check .",
    "dev": "tsx src/index.ts",
    "format": "biome format --write .",
    "lint": "biome check . && tsc -p tsconfig.json --noEmit",
    "lint:fix": "biome check --write .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "commander": "^14.0.1",
    "enquirer": "^2.4.1",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/node": "^24.3.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
